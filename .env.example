# Database
DATABASE_URL=sqlite+aiosqlite:///./kwork_scraper.db

# Telegram Bot (for reports and CI notifications)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id
TELEGRAM_ADMIN_ID=your_admin_id  # ID администратора бота (можно несколько через запятую)

# CI Notifications
CI_TELEGRAM_NOTIFY=false  # Set to true to enable Telegram notifications for CI

# Webhook Configuration
WEBHOOK_SECRET=your_secure_webhook_secret  # Must match the secret in your Git provider
MAIN_BRANCH=main  # The main branch that triggers full CI pipeline
WEBHOOK_PORT=8000  # Port for the webhook server

# JWT Authentication
SECRET_KEY=your_secure_jwt_secret_key  # Change this in production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30  # Access token lifetime in minutes
REFRESH_TOKEN_EXPIRE_DAYS=7     # Refresh token lifetime in days
ALLOWED_HOSTS=localhost,127.0.0.1  # Comma-separated list of allowed hosts

# CI Authentication
AUTH_ENABLED=true  # Set to false to disable authentication for development
AUTH_URL=http://localhost:8000/api/auth  # Base URL for authentication endpoints
API_BASE_URL=http://localhost:8000/api   # Base URL for API endpoints
CI_USERNAME=ci_user  # Username for CI service account
CI_PASSWORD=ci_password  # Password for CI service account

# UI Configuration
UI_ADMIN_TOKEN=your_secure_ui_token  # Token for accessing the web UI (change in production)
UI_TEST_TOKEN=test_ui_token_123  # Token for testing Web UI

# Kwork API Authentication
KWORK_USERNAME=your_username  # Логин от Kwork
KWORK_PASSWORD=your_password  # Пароль от Kwork
KWORK_PINCODE=your_pin       # Пин-код для входа (если включена 2FA)

# Node.js Bridge
KWORK_NODE_PATH=node  # Путь к Node.js (по умолчанию: node из PATH)

# Scraper Settings
HEADLESS=true
BROWSER_POOL_SIZE=3

# Kwork API Settings
KWORK_TOKEN=your_kwork_token_here  # Получить на https://kwork.ru/developer
POLL_INTERVAL=300  # Интервал проверки заказов в секундах (по умолчанию: 300 = 5 минут)

# LLM Settings
LLM_MODEL_PATH=models/mistral-7b-instruct-v0.2.Q4_K_M.gguf  # Путь к модели LLM
LLM_CONTEXT_SIZE=2048  # Размер контекста для модели
LLM_TEMPERATURE=0.7  # Температура генерации (0.1-1.0)
LLM_TOP_P=0.9  # Top-p sampling (0.1-1.0)
LLM_MAX_TOKENS=500  # Максимальное количество токенов в ответе

# Kwork Reply Settings
DRY_RUN=true  # Включить тестовый режим (не отправлять реальные отклики)
REPLY_DELAY=30  # Задержка перед отправкой отклика в секундах

# Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=logs/jarvis.log  # Файл для записи логов
MAX_PAGES=10
REQUEST_DELAY=2.0  # seconds between requests
