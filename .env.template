# ===== ОСНОВНЫЕ НАСТРОЙКИ =====
# Режим отладки (False в продакшене!)
DEBUG=False

# ===== TELEGRAM БОТ =====
# Получить у @BotFather
TELEGRAM_TOKEN=your-telegram-bot-token
# Узнать у @userinfobot
TELEGRAM_ADMIN_ID=6904521519
# Формат сообщений (markdown/html/plain)
TELEGRAM_PARSE_MODE=markdown

# ===== НАСТРОЙКИ УВЕДОМЛЕНИЙ =====
# Включить все типы уведомлений
NOTIFICATIONS_ENABLED=true
# Какие события уведомлять
NOTIFY_NEW_ORDER=true
NOTIFY_REPLY_RESULT=true
NOTIFY_ERRORS=true
# Задержка между уведомлениями (сек)
NOTIFICATION_DELAY=1.0
# Макс. длина сообщения (0 = без ограничений)
MAX_MESSAGE_LENGTH=4000

# ===== KWORK =====
# Ключевые слова для поиска (через запятую)
KEYWORDS=python,парсинг,автоматизация
# Интервал проверки (сек)
POLL_INTERVAL=300
# Макс. откликов за цикл
MAX_REPLIES_PER_RUN=5
# Задержка между действиями (сек)
DELAY_BETWEEN_ACTIONS=5

# ===== БАЗА ДАННЫХ =====
# Railway автоматически подставит DATABASE_URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/railway

# ===== НАСТРОЙКИ ЛОГИРОВАНИЯ =====
# Уровень логирования (DEBUG/INFO/WARNING/ERROR/CRITICAL)
LOG_LEVEL=INFO
